generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Tabela do Cardápio
model Product {
  id          Int      @id @default(autoincrement())
  category    String
  nome        String
  description String
  price       Float
  image       String?
  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Admin {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


// Tabela de Controle Financeiro
model Transacao {
  id          Int      @id @default(autoincrement())
  tipo        String   // "RECEITA" ou "DESPESA"
  descricao   String
  valor       Float
  categoria   String   // ex: "Pedido", "Ingredientes", "Contas", "Embalagens", "Salários", "Outro"
  data        DateTime @default(now())
  createdAt   DateTime @default(now())
}
